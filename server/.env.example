# MongoDB URI (Atlas recommended for production)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.abc.mongodb.net/nexlogica?retryWrites=true&w=majority
REDIS_URL=redis://default:<password>@<host>:<port>

# Port (optional, Vercel manages this automatically)
PORT=5000

# Security
JWT_SECRET=your_jwt_secret_change_me
KEY=your_encryption_key_change_me

# Blockchain
CONTRACT_ADDRESS=0xyour_contract_address_placeholder
ALCHEMY_AMOY_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
PRIVATE_KEY=0x_your_private_wallet_key_here

# CORS (your frontend URL)
CORS_ORIGIN=https://your-frontend-domain.vercel.app
